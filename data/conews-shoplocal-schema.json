{
  "version": "2026-05-14",
  "status": "planning-ready",
  "guardrails": [
    "No fabricated reviews, hours, prices, traffic, or revenue claims.",
    "Sponsored content must be labeled.",
    "Every paid placement must include a tracking slug.",
    "Do not import real customer data without explicit approval.",
    "Use needs_verification for seeded listings until a human verifies them."
  ],
  "requiredFields": [
    {
      "key": "business_name",
      "label": "Business Name",
      "type": "string"
    },
    {
      "key": "town",
      "label": "Town",
      "type": "town_slug"
    },
    {
      "key": "category",
      "label": "Category",
      "type": "category_slug"
    },
    {
      "key": "short_description",
      "label": "Short Description",
      "type": "string",
      "maxLength": 180
    },
    {
      "key": "address",
      "label": "Address",
      "type": "string"
    },
    {
      "key": "phone",
      "label": "Phone",
      "type": "phone"
    },
    {
      "key": "website",
      "label": "Website",
      "type": "url"
    },
    {
      "key": "contact_email",
      "label": "Contact Email",
      "type": "email"
    },
    {
      "key": "verification_status",
      "label": "Verification Status",
      "type": "enum",
      "values": ["needs_verification", "claimed", "verified", "rejected"]
    },
    {
      "key": "tier",
      "label": "Listing Tier",
      "type": "enum",
      "values": ["free", "featured", "sponsor", "partner"]
    }
  ],
  "optionalFields": [
    "logo",
    "hero_image",
    "gallery",
    "menu_url",
    "booking_url",
    "social_links",
    "hours",
    "latitude",
    "longitude",
    "sponsor_start",
    "sponsor_end",
    "tracking_slug",
    "editorial_notes",
    "claim_status",
    "last_verified_at"
  ],
