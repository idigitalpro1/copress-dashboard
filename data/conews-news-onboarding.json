{
  "_meta": {
    "title": "CoNews News-Asset Onboarding — Schema + Tenant Registry",
    "purpose": "Canonical contract for onboarding a news site as a TENANT of the shared Villager backend (one multi-tenant admin, deep-linked from SATCOM). Mirrors the 5280 town-rollout model for news brands.",
    "generated": "2026-06-21",
    "decisions": {
      "admin": "ONE multi-tenant admin in thevillager.today (scoped by site_key). No per-site admin clones.",
      "backend": "Shared backend; every record carries a site_key column (registercall/Supabase pattern).",
      "frontend": "One themeable build per brand OR distinct front-ends — both read the shared backend.",
      "control_plane": "SATCOM /portfolio lists every tenant and deep-links into the Villager admin at ?site=<site_key>."
    }
  },
  "schema": {
    "site_key": "string · unique slug · primary tenant key (e.g. 'denver-daily-post')",
    "name": "string · display name",
    "domain": "string · canonical public host",
    "market": "enum · metro | 5280 | national",
    "category": "enum · news | town | activity | national",
    "status": "enum · planned | provisioning | pilot | live | deprecated",
    "brand": {
      "masthead": "string",
      "theme": "string · theme key for the shared front-end build",
      "palette": "string · optional brand palette token"
    },
    "admin": {
      "surface": "https://www.thevillager.today/admin",
      "deep_link": "string · https://www.thevillager.today/admin?site=<site_key>",
      "clone": false
    },
    "backend": {
      "shared": true,
      "store": "supabase|mysql",
      "tenant_column": "site_key"
    },
    "editorial": {
      "lead": "string · author lane",
      "sections": "string[] · category slugs to seed",
      "seo_pillars": "string[] · optional"
    },
    "commerce": {
      "banner_eligible": "bool · selectable for client kits in SATCOM",
      "kits": "string[] · campaign kit slugs"
    },
    "dns": {
      "provider": "string",
      "target": "string",
      "status": "enum · pending | live"
    },
    "onboarding_checklist": [
      "1. register in conews-portfolio.json (SATCOM card auto-appears)",
      "2. create site_key tenant in shared backend",
      "3. seed sections/categories",
      "4. add site_key to Villager admin site-switcher (no new code)",
      "5. DNS/host (operator-gated)",
      "6. seed 5-10 launch articles",
      "7. mark banner_eligible + attach kits",
      "8. flip status planned -> live"
    ]
  },
